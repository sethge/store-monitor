{
  "manifest_version": 3,
  "name": "小q助手",
  "version": "5.2.1",
  "description": "运营助手 — 巡店预警/调整复盘/交流",
  "permissions": [
    "storage",
    "webRequest",
    "scripting",
    "tabs",
    "cookies",
    "alarms"
  ],
  "host_permissions": [
    "*://*.waimai.meituan.com/*",
    "*://*.meituan.com/*",
    "*://*.ele.me/*",
    "*://*.faas.ele.me/*",
    "*://*.eleme.cn/*",
    "*://*.koubei.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "小q助手"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.waimai.meituan.com/*",
        "*://*.meituan.com/*",
        "*://*.ele.me/*",
        "*://*.faas.ele.me/*",
        "*://*.eleme.cn/*"
      ],
      "js": ["content-ops-reader.js", "content-inject.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["operators.json"],
      "matches": ["<all_urls>"]
    }
  ]
}
