{
  "manifest_version": 3,
  "name": "小q助手",
  "version": "3.4.0",
  "description": "运营助手 — 日报/预警/操作记录/数据复盘/巡检控制",
  "permissions": [
    "storage",
    "webRequest",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "*://*.waimai.meituan.com/*",
    "*://*.meituan.com/*",
    "*://*.ele.me/*",
    "*://*.eleme.cn/*",
    "*://*.koubei.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Ops Logger"
  }
}
