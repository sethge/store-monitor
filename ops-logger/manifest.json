{
  "manifest_version": 3,
  "name": "小q助手",
  "version": "3.5.0",
  "description": "运营助手 — 日报/预警/操作记录/数据复盘/AI聊天",
  "permissions": [
    "storage",
    "webRequest",
    "scripting",
    "tabs",
    "sidePanel"
  ],
  "host_permissions": [
    "*://*.waimai.meituan.com/*",
    "*://*.meituan.com/*",
    "*://*.ele.me/*",
    "*://*.eleme.cn/*",
    "*://*.koubei.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "小q助手"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "web_accessible_resources": [
    {
      "resources": ["operators.json"],
      "matches": ["<all_urls>"]
    }
  ]
}
