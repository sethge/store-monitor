{
  "manifest_version": 3,
  "name": "小q助手",
  "version": "4.9.2",
  "description": "运营助手 — 巡店预警/调整复盘/交流",
  "permissions": [
    "storage",
    "webRequest",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "*://*.waimai.meituan.com/*",
    "*://*.meituan.com/*",
    "*://*.ele.me/*",
    "*://*.eleme.cn/*",
    "*://*.koubei.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "小q助手"
  },
  "web_accessible_resources": [
    {
      "resources": ["operators.json"],
      "matches": ["<all_urls>"]
    }
  ]
}
